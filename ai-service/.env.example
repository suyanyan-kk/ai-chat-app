DATABASE_URL=postgresql+psycopg://user:password@127.0.0.1:5432/ai_project

# Optional bootstrap account. Both values must be provided together.
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
AUTH_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
AUTH_BOOTSTRAP_ADMIN_NAME=System Administrator

AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_REFRESH_COOKIE_NAME=ai_refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=300
AUTH_TRUST_PROXY_HEADERS=false
