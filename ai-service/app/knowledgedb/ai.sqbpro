    id INTEGER PRIMARY KEY AUTOINCREMENT,

    file_id INTEGER,

    chunk_index INTEGER DEFAULT 0,

    content TEXT,

    embedding_status TEXT DEFAULT 'pending',

    vector_id TEXT,

    FOREIGN KEY(file_id)
    REFERENCES knowledge_file(id)

);</sql><current_tab id="0"/></tab_sql></sqlb_project>
